{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "." }
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/examples/vanilla/index.html" },
    { "source": "/style.css", "destination": "/dist/style.css" }
  ]
}
